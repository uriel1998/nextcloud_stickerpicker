{
	"name": "integration_stickers",
	"version": "0.0.1",
	"description": "Local sticker picker integration for Nextcloud Talk",
	"type": "module",
	"scripts": {
		"build": "NODE_ENV=production vite --mode production build",
		"dev": "NODE_ENV=development vite --mode development build",
		"watch": "NODE_ENV=development vite --mode development build --watch",
		"lint": "eslint --ext .js,.vue src"
	},
	"browserslist": [
		"extends @nextcloud/browserslist-config"
	],
	"engines": {
		"node": "^18 || ^20",
		"npm": "^9 || ^10"
	},
	"dependencies": {
		"@nextcloud/axios": "^2.4.0",
		"@nextcloud/router": "^3.0.0",
		"@nextcloud/vue": "^9.0.0",
		"vue": "^3.5.22",
		"vue-material-design-icons": "^5.1.2"
	},
	"devDependencies": {
		"@nextcloud/browserslist-config": "^3.0.0",
		"@nextcloud/eslint-config": "^8.0.0",
		"@nextcloud/vite-config": "^2.5.0",
		"vite": "^7.1.12",
		"vite-plugin-eslint": "^1.8.1",
		"@vitejs/plugin-vue": "^6.0.4"
	}
}
